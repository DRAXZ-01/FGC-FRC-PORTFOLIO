package src.vision;

import java.util.List;
import java.util.Optional;

import org.photonvision.EstimatedRobotPose;
import org.photonvision.PhotonCamera;
import org.photonvision.PhotonPoseEstimator;
import org.photonvision.PhotonUtils;
import org.photonvision.targeting.PhotonPipelineResult;

import edu.wpi.first.apriltag.AprilTagFieldLayout;
import edu.wpi.first.apriltag.AprilTagFields;
import edu.wpi.first.math.Matrix;
import edu.wpi.first.math.VecBuilder;
import edu.wpi.first.math.geometry.Pose2d;
import edu.wpi.first.math.geometry.Rotation3d;
import edu.wpi.first.math.geometry.Transform3d;
import edu.wpi.first.math.numbers.N1;
import edu.wpi.first.math.numbers.N3;
import edu.wpi.first.math.util.Units;
import edu.wpi.first.wpilibj2.command.SubsystemBase;

/**
 * Subsistema de Visão responsável por processar os dados do PhotonVision.
 * Estima a posição do robô no campo e calcula distâncias/ângulos relativos às AprilTags.
 */
public class Vision extends SubsystemBase {

  // Componentes principais do PhotonVision e layout do campo
  private final PhotonCamera camera;
  private final PhotonPoseEstimator photonPoseEstimator;
  private final AprilTagFieldLayout aprilTagLayout;

  // Variáveis para armazenar o ângulo e distância relativos ao alvo principal (best target)
  private double rotation;
  private double distance;

  // Define a posição física da câmera no robô em relação ao centro (origem).
  // X: frente/trás, Y: esquerda/direita, Z: cima/baixo.
  // Valores atuais: 43cm pra trás, 53cm pra esquerda.
  private final Transform3d robotToCam = new Transform3d(
      -0.43, 0.53, 0,
      new Rotation3d(
          Units.degreesToRadians(0),    // Roll (giro lateral)
          Units.degreesToRadians(30),   // Pitch (inclinada 30 graus para cima)
          Units.degreesToRadians(-10)   // Yaw (angulada 10 graus para a direita)
      )
  );

  // Armazena a última pose (posição global) calculada com sucesso pela visão
  private Optional<EstimatedRobotPose> latestPoseEstimate = Optional.empty();

  /**
   * Construtor da classe Vision.
   */
  public Vision() {
    // Carrega o layout de AprilTags padrão da temporada (k2026RebuiltWelded)
    aprilTagLayout = AprilTagFieldLayout.loadField(AprilTagFields.k2026RebuiltWelded);
    
    // Inicializa a câmera usando o exato nome configurado no painel do PhotonVision
    camera = new PhotonCamera("Arducam_OV9281_USB_Camera");

    // Configura o estimador de posição da PhotonVision
    photonPoseEstimator = new PhotonPoseEstimator(
        aprilTagLayout,
        PhotonPoseEstimator.PoseStrategy.LOWEST_AMBIGUITY, // Usa a tag mais nítida/menos ambígua para calcular a pose
        robotToCam
    );
  }

  // Retorna a posição do robô calculada no frame atual
  public Optional<EstimatedRobotPose> getPoseEstimate() {
    return latestPoseEstimate;
  }

  /**
   * Calcula o "peso" da estimativa da visão baseado na distância do robô até a tag.
   * Utilizado para alimentar o PoseEstimator principal do Drivetrain (fuzão de sensores).
   * @param estimatedPose Pose atual do robô vinda da odometria
   * @return Matriz de desvio padrão (X, Y, Theta)
   */
  public Matrix<N3, N1> getEstimationStdDevs(Pose2d estimatedPose) {
    var results = camera.getLatestResult();
    var targets = results.getTargets();

    int numTags = 0;
    double avgDist = 0;

    // Soma a distância entre o robô e todas as tags vistas no frame
    for (var tgt : targets) {
      var tagPose = aprilTagLayout.getTagPose(tgt.getFiducialId());
      if (tagPose.isPresent()) {
        numTags++;
        avgDist += tagPose.get().toPose2d().getTranslation()
            .getDistance(estimatedPose.getTranslation());
      }
    }

    // Se nenhuma tag for vista, retorna um desvio neutro
    if (numTags == 0) return VecBuilder.fill(1, 1, 1);

    avgDist /= numTags; // Média da distância das tags

    // Se a média da distância for maior que 2 metros, reduzimos a confiança na visão (valores maiores)
    if (avgDist > 2) {
      return VecBuilder.fill(0.5, 0.5, 3.0); // baixa confiança
    } else {
      // Se estiver mais perto, aumentamos a confiança (valores menores)
      return VecBuilder.fill(0.25, 0.25, 2.0); // média confiança
    }
  }

  // Getters para a rotação (yaw) e distância da melhor tag
  public double getRotation() {
    return rotation;
  }

  public double getDistance() {
    return distance;
  }

  /**
   * Loop executado a cada ~20ms pelo scheduler do robô.
   */
  @Override
  public void periodic() {
    // Busca todos os frames que a câmera processou desde o último ciclo
    List<PhotonPipelineResult> results = camera.getAllUnreadResults();

    for (PhotonPipelineResult result : results) {

      // Se não identificar nenhuma tag, limpa a estimativa de pose e pula
      if (!result.hasTargets()) {
        latestPoseEstimate = Optional.empty();
        continue;
      }

      var bestTarget = result.getBestTarget();

      // Filtro de ruído: Descarta o frame se a ambiguidade for maior que 20%
      // Isso evita que o robô ache que está em uma posição falsa espelhada do campo
      if (bestTarget.getPoseAmbiguity() > 0.2) {
        latestPoseEstimate = Optional.empty();
        continue;
      }

      // Salva o ângulo horizontal (yaw) do robô até a tag
      rotation = bestTarget.getYaw();

      // Tenta pegar a pose real da tag no mapa para calcular a distância
      var tagPose = aprilTagLayout.getTagPose(bestTarget.getFiducialId());
      if (tagPose.isPresent()) {
        distance = PhotonUtils.calculateDistanceToTargetMeters(
            0.53, // Altura da lente da câmera até o chão em metros
            tagPose.get().getZ(), // Altura do centro da AprilTag no campo
            Units.degreesToRadians(30), // Inclinação (pitch) estática da câmera
            Units.degreesToRadians(bestTarget.getPitch()) // Inclinação (pitch) lida do alvo
        );
      }

      // Atualiza a posição estimada final para ser lida por outros subsistemas
      latestPoseEstimate = photonPoseEstimator.update(result);
    }
  }
}